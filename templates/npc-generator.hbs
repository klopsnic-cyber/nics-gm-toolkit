<div class="gmtk-body">
  <div class="gmtk-row">
    <div class="form-group">
      <label>Volk</label>
      <select name="race">{{selectOptions races selected=opts.race}}</select>
    </div>
    <div class="form-group">
      <label>Geschlecht</label>
      <select name="gender">{{selectOptions genders selected=opts.gender}}</select>
    </div>
    <div class="form-group">
      <label>Beruf</label>
      <select name="role">{{selectOptions roles selected=opts.role}}</select>
    </div>
  </div>
  <div class="gmtk-row">
    <div class="form-group">
      <label>Klasse</label>
      <select name="klass">{{selectOptions classChoices selected=opts.klass}}</select>
    </div>
    <div class="form-group">
      <label>Stufe</label>
      <select name="level">{{selectOptions levelChoices selected=opts.level}}</select>
    </div>
  </div>

  <button type="button" class="gmtk-primary" data-action="generate">
    <i class="fa-solid fa-dice"></i> NSC generieren
  </button>

  {{#if npc}}
  <div class="gmtk-result">
    <h2>{{npc.name}}</h2>
    <p class="gmtk-sub">{{npc.raceLabel}} · {{npc.genderLabel}} · {{npc.age}} Jahre · {{npc.roleLabel}} · {{npc.classLine}}</p>
    <p class="gmtk-stats">{{npc.statLine}}</p>
    <dl>
      <dt>Aussehen</dt><dd>{{npc.appearance}}</dd>
      <dt>Persönlichkeit</dt><dd>{{npc.personality}}</dd>
      <dt>Stimme</dt><dd>{{npc.voice}}</dd>
      <dt>Marotte</dt><dd>{{npc.quirk}}</dd>
      <dt>Motivation</dt><dd>{{npc.motivation}}</dd>
      <dt>Taschen</dt><dd>{{npc.pockets}}</dd>
      {{#if npc.spells}}
      <dt>Zauber</dt>
      <dd>
        {{#each npc.spells}}
        <div><b>{{this.grade}}:</b> {{#each this.spells}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
        {{/each}}
      </dd>
      {{/if}}
      <dt class="gmtk-secret">Geheimnis</dt><dd class="gmtk-secret">{{npc.secret}}</dd>
      <dt class="gmtk-secret">Aufhänger</dt><dd class="gmtk-secret">{{npc.hook}}</dd>
    </dl>
    <div class="gmtk-actions">
      <button type="button" data-action="createActor"><i class="fa-solid fa-user"></i> Als Actor</button>
      <button type="button" data-action="saveJournal"><i class="fa-solid fa-book"></i> Als Journal</button>
      <button type="button" data-action="toChat"><i class="fa-solid fa-comment"></i> In den Chat</button>
    </div>
  </div>
  {{/if}}
</div>
